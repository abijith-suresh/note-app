{
  "name": "interleaf",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "verify": "bun run typecheck && bun run typecheck:node && bun run lint && bun run format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/geist": "^5.1.0",
    "@fontsource/newsreader": "^5.2.10",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "fuse.js": "^7.1.0",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "marked": "^15.0.12",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^25.6.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-solid": "^2.11.6"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx,css,json}": [
      "bunx biome check --write --no-errors-on-unmatched"
    ]
  }
}
